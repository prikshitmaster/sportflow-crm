{
  "name": "sportflow-crm",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:students": "playwright test add-student",
    "test:payments": "playwright test payments",
    "electron:dev": "concurrently -n vite,electron -c blue,green \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:preview": "vite build --base ./ && electron .",
    "electron:build": "vite build --base ./ && electron-builder"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.1",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@sentry/react": "^10.53.1",
    "@supabase/supabase-js": "^2.105.1",
    "date-fns": "^3.6.0",
    "exceljs": "^4.4.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.436.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "xlsx-js-style": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "pg": "^8.21.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^6.0.3",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^8.0.5"
  }
}
